<Window xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Darwinbots.Desktop.Views.DnaEditorWindow" Title="Darwinbots DNA Editor"
        Width="760" Height="620" MinWidth="600" MinHeight="460" WindowStartupLocation="CenterOwner">
  <Grid RowDefinitions="54,*,52">
    <Border Background="#FBF9F2" BorderBrush="#C8C5BB" BorderThickness="0,0,0,1" Padding="16">
      <Grid ColumnDefinitions="*,Auto"><TextBlock Text="DNA EDITOR" FontFamily="Bahnschrift" FontSize="20" FontWeight="Bold"/><TextBlock Grid.Column="1" x:Name="Identity" VerticalAlignment="Center"/></Grid>
    </Border>
    <TextBox Grid.Row="1" x:Name="Editor" AcceptsReturn="True" TextWrapping="NoWrap" FontFamily="Cascadia Mono, Consolas" FontSize="14" Margin="12" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
    <Border Grid.Row="2" Background="#E6E2D8" BorderBrush="#C8C5BB" BorderThickness="0,1,0,0" Padding="10,8">
      <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
        <TextBlock x:Name="Status" VerticalAlignment="Center"/>
        <Button Grid.Column="1" Content="SAVE BOT" Click="Save_Click"/>
        <Button Grid.Column="2" Content="APPLY + CLONE" Click="Clone_Click"/>
        <Button Grid.Column="3" Content="APPLY DNA" Background="#4C7D30" Foreground="White" Click="Apply_Click"/>
      </Grid>
    </Border>
  </Grid>
</Window>
